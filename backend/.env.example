# EasySDR Prospecting System Configuration Template
PROJECT_NAME="EasySDR Engine"
DATABASE_URL="sqlite:///./prospecting.db"

# API Keys (Set to 'mock' for testing without keys)
APOLLO_API_KEY="your_apollo_api_key_here"
HUBSPOT_ACCESS_TOKEN="your_hubspot_developer_access_token_here"
DATANYZE_API_KEY="your_datanyze_api_key_here"
ZOOMINFO_API_KEY="your_zoominfo_api_key_here"

# Kimi Code AI Integration
KIMI_API_KEY="your_kimi_moonshot_api_key_here"
KIMI_BASE_URL="https://integrate.api.nvidia.com/v1"
KIMI_MODEL="moonshotai/kimi-k2.6"

# LinkedIn credentials (for Playwright login)
LINKEDIN_USERNAME="your_linkedin_email@domain.com"
LINKEDIN_PASSWORD="your_linkedin_password_here"
LINKEDIN_COOKIES_JSON="[]" # JSON string of session cookies
